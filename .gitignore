# Phenotype-org standard .gitignore — Python
# Source: https://github.com/KooshaPari/phenotype-tooling/blob/main/templates/gitignore-python

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
ENV/
env/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Editor
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Repo-specific additions (preserved from prior .gitignore)
!.env.example
.env
.env.*
*.class
*.log
/*-wtrees
/worktrees
coverage
node_modules
target
